{
  "$comment": "AUTO-GENERATED - DO NOT EDIT. Regenerate with: cargo run --bin generate_types",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "State",

  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "State",
  "type": "object",
  "properties": {
    "paused": {
      "type": "boolean"
    },
    "agents": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/AgentState"
      }
    },
    "completed": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/CompletedTicket"
      }
    },
    "project_llm_stats": {
      "description": "Per-project LLM usage statistics",
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/ProjectLlmStats"
      },
      "default": {}
    },
    "project_collection_prefs": {
      "description": "Per-project issue type collection preferences (`project_name` -> `collection_name`)",
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "default": {}
    },
    "multi_agent_groups": {
      "description": "Active multi-agent step groups (`multi_model`, `multi_prompt`, `matrixed`)",
      "type": "array",
      "items": {
        "$ref": "#/$defs/MultiAgentGroup"
      },
      "default": []
    }
  },
  "required": [
    "paused",
    "agents",
    "completed"
  ],
  "$defs": {
    "AgentState": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "ticket_id": {
          "type": "string"
        },
        "ticket_type": {
          "type": "string"
        },
        "project": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "started_at": {
          "type": "string",
          "format": "date-time"
        },
        "last_activity": {
          "type": "string",
          "format": "date-time"
        },
        "last_message": {
          "type": [
            "string",
            "null"
          ]
        },
        "paired": {
          "type": "boolean"
        },
        "session_name": {
          "description": "The terminal session name for this agent (for recovery)",
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "session_wrapper": {
          "description": "Which session wrapper manages this agent: \"tmux\", \"vscode\", or \"cmux\" (None = legacy tmux)",
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "session_window_ref": {
          "description": "Session window reference ID (top-level grouping: cmux window, tmux session, etc.)",
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "session_context_ref": {
          "description": "Session context reference ID (mid-level: cmux workspace, tmux window, etc.)",
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "session_pane_ref": {
          "description": "Session pane reference ID (leaf-level: cmux surface, tmux pane, etc.)",
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "content_hash": {
          "description": "Hash of the last captured pane content (for change detection)",
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "current_step": {
          "description": "Current step in the ticket workflow (e.g., \"plan\", \"implement\", \"test\")",
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "step_started_at": {
          "description": "When the current step started (for timeout detection)",
          "type": [
            "string",
            "null"
          ],
          "format": "date-time",
          "default": null
        },
        "last_content_change": {
          "description": "Last time content changed in the session (for hung detection)",
          "type": [
            "string",
            "null"
          ],
          "format": "date-time",
          "default": null
        },
        "pr_url": {
          "description": "PR URL if created during \"pr\" step",
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "pr_number": {
          "description": "PR number for GitHub API tracking",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0,
          "default": null
        },
        "github_repo": {
          "description": "GitHub repo in format \"owner/repo\"",
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "pr_status": {
          "description": "Last known PR status (\"open\", \"approved\", \"`changes_requested`\", \"merged\", \"closed\")",
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "completed_steps": {
          "description": "Completed steps for this ticket",
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "llm_tool": {
          "description": "LLM tool used (e.g., \"claude\", \"gemini\", \"codex\")",
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "llm_model": {
          "description": "LLM model alias (e.g., \"opus\", \"sonnet\", \"gpt-4o\")",
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "launch_mode": {
          "description": "Launch mode: \"default\", \"yolo\", \"docker\", \"docker-yolo\"",
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "review_state": {
          "description": "Review state for `awaiting_input` agents\nValues: \"`pending_plan`\", \"`pending_visual`\", \"`pending_pr_creation`\", \"`pending_pr_merge`\"",
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "dev_server_pid": {
          "description": "Server process ID for visual review cleanup (if applicable)",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0,
          "default": null
        },
        "worktree_path": {
          "description": "Path to the git worktree for this ticket (per-ticket isolation)",
          "type": [
            "string",
            "null"
          ],
          "default": null
        }
      },
      "required": [
        "id",
        "ticket_id",
        "ticket_type",
        "project",
        "status",
        "started_at",
        "last_activity",
        "paired"
      ]
    },
    "CompletedTicket": {
      "type": "object",
      "properties": {
        "ticket_id": {
          "type": "string"
        },
        "ticket_type": {
          "type": "string"
        },
        "project": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "completed_at": {
          "type": "string",
          "format": "date-time"
        },
        "pr_url": {
          "type": [
            "string",
            "null"
          ]
        },
        "output_tickets": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "ticket_id",
        "ticket_type",
        "project",
        "summary",
        "completed_at",
        "output_tickets"
      ]
    },
    "ProjectLlmStats": {
      "description": "LLM usage statistics for a project",
      "type": "object",
      "properties": {
        "project": {
          "description": "Project name",
          "type": "string"
        },
        "preferred_tool": {
          "description": "Preferred LLM tool for this project (user override)",
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "preferred_model": {
          "description": "Preferred model for this project (user override)",
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "tool_usage": {
          "description": "Usage history per LLM tool",
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/LlmToolUsage"
          },
          "default": {}
        },
        "updated_at": {
          "description": "Last updated timestamp",
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "project",
        "updated_at"
      ]
    },
    "LlmToolUsage": {
      "description": "Usage statistics for a specific LLM tool",
      "type": "object",
      "properties": {
        "tool": {
          "description": "Tool name (e.g., \"claude\", \"gemini\")",
          "type": "string"
        },
        "ticket_count": {
          "description": "Total number of tickets processed",
          "type": "integer",
          "format": "uint64",
          "minimum": 0,
          "default": 0
        },
        "success_count": {
          "description": "Number of successful completions",
          "type": "integer",
          "format": "uint64",
          "minimum": 0,
          "default": 0
        },
        "failure_count": {
          "description": "Number of failures/abandonments",
          "type": "integer",
          "format": "uint64",
          "minimum": 0,
          "default": 0
        },
        "total_time_secs": {
          "description": "Total time spent (in seconds)",
          "type": "integer",
          "format": "uint64",
          "minimum": 0,
          "default": 0
        },
        "last_used": {
          "description": "Last used timestamp",
          "type": "string",
          "format": "date-time"
        },
        "model_usage": {
          "description": "Per-model breakdown",
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/LlmModelUsage"
          },
          "default": {}
        }
      },
      "required": [
        "tool",
        "last_used"
      ]
    },
    "LlmModelUsage": {
      "description": "Usage statistics for a specific model",
      "type": "object",
      "properties": {
        "model": {
          "description": "Model name/alias",
          "type": "string"
        },
        "ticket_count": {
          "description": "Number of tickets",
          "type": "integer",
          "format": "uint64",
          "minimum": 0,
          "default": 0
        },
        "success_count": {
          "description": "Success count",
          "type": "integer",
          "format": "uint64",
          "minimum": 0,
          "default": 0
        },
        "failure_count": {
          "description": "Failure count",
          "type": "integer",
          "format": "uint64",
          "minimum": 0,
          "default": 0
        },
        "total_time_secs": {
          "description": "Total time (seconds)",
          "type": "integer",
          "format": "uint64",
          "minimum": 0,
          "default": 0
        }
      },
      "required": [
        "model"
      ]
    },
    "MultiAgentGroup": {
      "description": "Tracks a group of agents working on a single multi-agent step",
      "type": "object",
      "properties": {
        "group_id": {
          "description": "Unique group identifier",
          "type": "string"
        },
        "ticket_id": {
          "description": "Ticket this group belongs to",
          "type": "string"
        },
        "step_name": {
          "description": "Step name being executed",
          "type": "string"
        },
        "step_type": {
          "description": "Step type (`multi_model`, `multi_prompt`, `matrixed`)",
          "type": "string"
        },
        "agent_ids": {
          "description": "Agent IDs in this group (populated as sub-agents launch)",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "phase": {
          "description": "Current execution phase",
          "$ref": "#/$defs/MultiAgentPhase"
        },
        "individual_outputs": {
          "description": "Collected outputs from completed sub-agents, keyed by `variant_key`\n(delegator name for `multi_model`, index for `multi_prompt`,\n`{delegator}:{prompt_idx}` for `matrixed`).",
          "type": "object",
          "additionalProperties": true,
          "default": {}
        },
        "aggregated_output": {
          "description": "Final aggregated output (set when phase = Complete)",
          "default": null
        },
        "expected_total": {
          "description": "Total sub-agents expected (`agent_ids.len() + pending_launches.len()`).",
          "type": "integer",
          "format": "uint",
          "minimum": 0,
          "default": 0
        },
        "pending_launches": {
          "description": "Sub-agents that still need launching (waiting for a free slot).",
          "type": "array",
          "items": {
            "$ref": "#/$defs/PendingSubAgent"
          },
          "default": []
        },
        "agent_variant_keys": {
          "description": "Maps launched `agent_id` to the `variant_key` used as the output key.",
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "default": {}
        }
      },
      "required": [
        "group_id",
        "ticket_id",
        "step_name",
        "step_type",
        "agent_ids",
        "phase"
      ]
    },
    "MultiAgentPhase": {
      "description": "Execution phase for a multi-agent group",
      "oneOf": [
        {
          "description": "Phase 1: all sub-agents running the initial prompt",
          "type": "string",
          "const": "fan_out"
        },
        {
          "description": "Phase 2: voting/selection round (`multi_model` with `share_answers`)",
          "type": "string",
          "const": "voting"
        },
        {
          "description": "All done, aggregated output ready",
          "type": "string",
          "const": "complete"
        },
        {
          "description": "One or more sub-agents failed",
          "type": "string",
          "const": "failed"
        }
      ]
    },
    "PendingSubAgent": {
      "description": "A sub-agent that has been planned but not yet launched (slot queue).",
      "type": "object",
      "properties": {
        "delegator_name": {
          "description": "Delegator (from `config.delegators`) this sub-agent should use.",
          "type": "string"
        },
        "prompt": {
          "description": "Fully-rendered prompt text for this sub-agent.",
          "type": "string"
        },
        "variant_key": {
          "description": "Key under which this sub-agent's output is recorded (see `individual_outputs`).",
          "type": "string"
        }
      },
      "required": [
        "delegator_name",
        "prompt",
        "variant_key"
      ]
    }
  }
}