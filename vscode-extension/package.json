{
  "name": "operator-terminals",
  "displayName": "Operator! Terminals for vscode",
  "description": "VS Code terminal integration for Operator! multi-agent orchestration",
  "version": "0.2.2",
  "publisher": "untra",
  "author": {
    "name": "Samuel Volin",
    "email": "untra.sam@gmail.com",
    "url": "https://untra.io"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/untra/operator"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "operator",
    "terminal",
    "agent",
    "claude",
    "ai"
  ],
  "icon": "images/operator-logo-128.png",
  "activationEvents": [
    "onStartupFinished",
    "onUri",
    "onView:operator-status",
    "onView:operator-in-progress",
    "onView:operator-queue",
    "onView:operator-completed",
    "onCommand:operator.showStatus",
    "onCommand:operator.startOperatorServer",
    "onCommand:operator.launchTicket",
    "onCommand:operator.openSettings",
    "onCommand:operator.openWalkthrough",
    "onCommand:operator.selectWorkingDirectory"
  ],
  "main": "./out/src/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "operator-sidebar",
          "title": "Operator",
          "icon": "images/operator-icon-128.png"
        }
      ]
    },
    "views": {
      "operator-sidebar": [
        {
          "id": "operator-status",
          "name": "Status",
          "type": "tree"
        },
        {
          "id": "operator-in-progress",
          "name": "In Progress",
          "type": "tree"
        },
        {
          "id": "operator-queue",
          "name": "Queue",
          "type": "tree"
        },
        {
          "id": "operator-completed",
          "name": "Completed",
          "type": "tree",
          "visibility": "collapsed"
        }
      ]
    },
    "configuration": {
      "title": "Operator Terminals",
      "properties": {
        "operator.webhookPort": {
          "type": "number",
          "default": 7009,
          "description": "Preferred port for webhook server (falls back to available port if busy)"
        },
        "operator.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start webhook server on VS Code launch"
        },
        "operator.terminalPrefix": {
          "type": "string",
          "default": "op-",
          "description": "Prefix for operator-managed terminal names"
        },
        "operator.ticketsDir": {
          "type": "string",
          "default": ".tickets",
          "description": "Path to tickets directory (relative to workspace root or absolute)"
        },
        "operator.apiUrl": {
          "type": "string",
          "default": "http://localhost:7008",
          "description": "URL of the Operator REST API server"
        },
        "operator.opr8rPath": {
          "type": "string",
          "default": "",
          "description": "Path to opr8r binary (leave empty to use bundled or PATH)"
        },
        "operator.operatorPath": {
          "type": "string",
          "default": "",
          "description": "Path to operator binary (leave empty to use downloaded or PATH)"
        },
        "operator.workingDirectory": {
          "type": "string",
          "default": "",
          "description": "Working directory where Operator server runs (contains .tickets/ and project repos)"
        }
      }
    },
    "commands": [
      {
        "command": "operator.showStatus",
        "title": "Operator: Show Server Status"
      },
      {
        "command": "operator.refreshTickets",
        "title": "Refresh Tickets",
        "icon": "$(refresh)"
      },
      {
        "command": "operator.statusSpecialAction",
        "title": "Operator: Special Action (X)"
      },
      {
        "command": "operator.statusRefreshAction",
        "title": "Operator: Refresh Action (Y)"
      },
      {
        "command": "operator.statusBackAction",
        "title": "Operator: Go Back (B)"
      },
      {
        "command": "operator.focusTicket",
        "title": "Focus Terminal"
      },
      {
        "command": "operator.openTicket",
        "title": "Open Ticket"
      },
      {
        "command": "operator.launchTicket",
        "title": "Operator: Launch Ticket"
      },
      {
        "command": "operator.launchTicketWithOptions",
        "title": "Operator: Launch Ticket (with options)"
      },
      {
        "command": "operator.relaunchTicket",
        "title": "Relaunch Ticket",
        "icon": "$(debug-restart)"
      },
      {
        "command": "operator.launchTicketFromEditor",
        "title": "Operator: Launch Ticket from Editor"
      },
      {
        "command": "operator.launchTicketFromEditorWithOptions",
        "title": "Operator: Launch Ticket from Editor (with options)"
      },
      {
        "command": "operator.downloadOperator",
        "title": "Operator: Download Operator"
      },
      {
        "command": "operator.pauseQueue",
        "title": "Operator: Pause Queue Processing"
      },
      {
        "command": "operator.resumeQueue",
        "title": "Operator: Resume Queue Processing"
      },
      {
        "command": "operator.syncKanban",
        "title": "Operator: Sync Kanban Collections"
      },
      {
        "command": "operator.approveReview",
        "title": "Operator: Approve Review"
      },
      {
        "command": "operator.rejectReview",
        "title": "Operator: Reject Review"
      },
      {
        "command": "operator.startOperatorServer",
        "title": "Operator: Start Operator Server",
        "icon": "$(play)"
      },
      {
        "command": "operator.selectWorkingDirectory",
        "title": "Operator: Select Working Directory",
        "icon": "$(edit)"
      },
      {
        "command": "operator.checkKanbanConnection",
        "title": "Operator: Check Kanban Connection"
      },
      {
        "command": "operator.configureJira",
        "title": "Operator: Configure Jira"
      },
      {
        "command": "operator.configureLinear",
        "title": "Operator: Configure Linear"
      },
      {
        "command": "operator.startKanbanOnboarding",
        "title": "Operator: Configure Kanban Provider"
      },
      {
        "command": "operator.startGitOnboarding",
        "title": "Operator: Connect Git Provider"
      },
      {
        "command": "operator.configureGitHub",
        "title": "Operator: Connect GitHub"
      },
      {
        "command": "operator.configureGitLab",
        "title": "Operator: Connect GitLab"
      },
      {
        "command": "operator.showCreateMenu",
        "title": "Operator: Create New..."
      },
      {
        "command": "operator.openCreateDelegator",
        "title": "Operator: Create Delegator"
      },
      {
        "command": "operator.detectLlmTools",
        "title": "Operator: Detect LLM Tools"
      },
      {
        "command": "operator.setDefaultLlm",
        "title": "Operator: Set Default LLM"
      },
      {
        "command": "operator.openWalkthrough",
        "title": "Operator: Open Setup Walkthrough"
      },
      {
        "command": "operator.openSettings",
        "title": "Operator: Open Settings"
      },
      {
        "command": "operator.openUi",
        "title": "Operator: Open Operator UI",
        "icon": "$(globe)"
      },
      {
        "command": "operator.openIssueTypes",
        "title": "Operator: Open Issue Types in Operator UI"
      },
      {
        "command": "operator.openProjects",
        "title": "Operator: Open Projects in Operator UI"
      },
      {
        "command": "operator.openKanban",
        "title": "Operator: Open Kanban Board in Operator UI"
      },
      {
        "command": "operator.openQueue",
        "title": "Operator: Open Queue in Operator UI",
        "icon": "$(globe)"
      },
      {
        "command": "operator.syncKanbanCollection",
        "title": "Operator: Sync Collection"
      },
      {
        "command": "operator.addJiraProject",
        "title": "Operator: Add Jira Project"
      },
      {
        "command": "operator.addLinearTeam",
        "title": "Operator: Add Linear Team"
      },
      {
        "command": "operator.revealTicketsDir",
        "title": "Operator: Reveal Tickets Directory"
      },
      {
        "command": "operator.connectMcpServer",
        "title": "Operator: Connect MCP Server",
        "icon": "$(plug)"
      },
      {
        "command": "operator.runSetup",
        "title": "Operator: Run Setup"
      },
      {
        "command": "operator.startWebhookServer",
        "title": "Operator: Start Webhook Server"
      }
    ],
    "keybindings": [
      {
        "command": "operator.statusSpecialAction",
        "key": "shift+enter",
        "when": "focusedView == operator-status"
      },
      {
        "command": "operator.statusRefreshAction",
        "key": "ctrl+enter",
        "when": "focusedView == operator-status"
      },
      {
        "command": "operator.statusBackAction",
        "key": "escape",
        "when": "focusedView == operator-status && listHasSelectionOrFocus"
      },
      {
        "command": "operator.launchTicketWithOptions",
        "key": "enter",
        "when": "focusedView == operator-queue && listHasSelectionOrFocus"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "operator.refreshTickets",
          "when": "view =~ /operator-/",
          "group": "navigation"
        },
        {
          "command": "operator.openUi",
          "when": "view == operator-status",
          "group": "navigation"
        },
        {
          "command": "operator.openQueue",
          "when": "view == operator-queue",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "operator.focusTicket",
          "when": "view == operator-in-progress",
          "group": "inline"
        },
        {
          "command": "operator.relaunchTicket",
          "when": "view == operator-in-progress",
          "group": "inline"
        },
        {
          "command": "operator.launchTicket",
          "when": "view == operator-queue",
          "group": "inline"
        },
        {
          "command": "operator.syncKanbanCollection",
          "when": "view == operator-status && viewItem == kanbanSyncConfig",
          "group": "inline"
        },
        {
          "command": "operator.selectWorkingDirectory",
          "when": "view == operator-status && viewItem == workingDirConfigured",
          "group": "inline"
        }
      ],
      "editor/context": [
        {
          "command": "operator.launchTicketFromEditor",
          "when": "resourcePath =~ /\\.tickets\\/(queue|in-progress)\\/.+\\.md$/",
          "group": "operator@1"
        },
        {
          "command": "operator.launchTicketFromEditorWithOptions",
          "when": "resourcePath =~ /\\.tickets\\/(queue|in-progress)\\/.+\\.md$/",
          "group": "operator@2"
        }
      ],
      "commandPalette": [
        {
          "command": "operator.startOperatorServer",
          "when": "operator.operatorAvailable && operator.ticketsParentFound"
        }
      ]
    },
    "walkthroughs": [
      {
        "id": "operator-setup",
        "title": "Operator! Setup",
        "when": "!operator.workingDirectorySet",
        "description": "Configure Operator! to orchestrate LLM coding agents across many code repositories",
        "icon": "images/operator-icon-128.png",
        "featuredFor": [
          "CLAUDE.md",
          "AGENTS.md"
        ],
        "steps": [
          {
            "id": "download-operator",
            "title": "Download Operator",
            "description": "Download the Operator server binary to orchestrate LLM coding agents.\n\n[Download Operator](command:operator.downloadOperator)",
            "media": {
              "markdown": "walkthrough/welcome.md"
            },
            "completionEvents": [
              "onContext:operator.operatorAvailable"
            ]
          },
          {
            "id": "select-working-directory",
            "title": "Select Working Directory",
            "description": "Choose a parent directory for your repositories.\n\n[Select Directory](command:operator.selectWorkingDirectory)",
            "media": {
              "markdown": "walkthrough/select-directory.md"
            },
            "completionEvents": [
              "onContext:operator.workingDirectorySet"
            ]
          },
          {
            "id": "connect-kanban",
            "title": "Connect Kanban Provider",
            "description": "Connect to Jira Cloud or Linear.\n\n[Configure Now](command:operator.startKanbanOnboarding)",
            "media": {
              "markdown": "walkthrough/connect-kanban.md"
            },
            "completionEvents": [
              "onContext:operator.kanbanConnected"
            ]
          },
          {
            "id": "install-llm-tool",
            "title": "Detect LLM Tools",
            "description": "Install a [Supported Coding Agent](https://operator.untra.io/getting-started/agents/), such as **Claude Code**.\n\n[Detect Tools](command:operator.detectLlmTools)",
            "media": {
              "markdown": "walkthrough/install-llm-tool.md"
            },
            "completionEvents": [
              "onContext:operator.llmToolInstalled"
            ]
          }
        ]
      }
    ],
    "icons": {
      "operator-atlassian": {
        "description": "Atlassian (Jira) provider icon",
        "default": {
          "fontPath": "images/icons/dist/operator-icons.woff",
          "fontCharacter": "\\F112"
        }
      },
      "operator-linear": {
        "description": "Linear provider icon",
        "default": {
          "fontPath": "images/icons/dist/operator-icons.woff",
          "fontCharacter": "\\F109"
        }
      },
      "operator-claude": {
        "description": "Claude LLM tool icon",
        "default": {
          "fontPath": "images/icons/dist/operator-icons.woff",
          "fontCharacter": "\\F111"
        }
      },
      "operator-codex": {
        "description": "Codex LLM tool icon",
        "default": {
          "fontPath": "images/icons/dist/operator-icons.woff",
          "fontCharacter": "\\F10E"
        }
      },
      "operator-gemini": {
        "description": "Gemini LLM tool icon",
        "default": {
          "fontPath": "images/icons/dist/operator-icons.woff",
          "fontCharacter": "\\F10D"
        }
      },
      "operator-google": {
        "description": "Google (Gemini API) model-server icon",
        "default": {
          "fontPath": "images/icons/dist/operator-icons.woff",
          "fontCharacter": "\\F10A"
        }
      },
      "operator-anthropic": {
        "description": "Anthropic (Claude API) model-server icon",
        "default": {
          "fontPath": "images/icons/dist/operator-icons.woff",
          "fontCharacter": "\\F113"
        }
      },
      "operator-ollama": {
        "description": "Ollama model-provider icon",
        "default": {
          "fontPath": "images/icons/dist/operator-icons.woff",
          "fontCharacter": "\\F107"
        }
      },
      "operator-openrouter": {
        "description": "OpenRouter model-provider icon",
        "default": {
          "fontPath": "images/icons/dist/operator-icons.woff",
          "fontCharacter": "\\F106"
        }
      },
      "operator-github": {
        "description": "GitHub provider icon",
        "default": {
          "fontPath": "images/icons/dist/operator-icons.woff",
          "fontCharacter": "\\F10C"
        }
      },
      "operator-gitlab": {
        "description": "GitLab provider icon",
        "default": {
          "fontPath": "images/icons/dist/operator-icons.woff",
          "fontCharacter": "\\F10B"
        }
      },
      "operator-tmux": {
        "description": "tmux session wrapper icon",
        "default": {
          "fontPath": "images/icons/dist/operator-icons.woff",
          "fontCharacter": "\\F105"
        }
      },
      "operator-cmux": {
        "description": "cmux session wrapper icon",
        "default": {
          "fontPath": "images/icons/dist/operator-icons.woff",
          "fontCharacter": "\\F110"
        }
      },
      "operator-zellij": {
        "description": "Zellij session wrapper icon",
        "default": {
          "fontPath": "images/icons/dist/operator-icons.woff",
          "fontCharacter": "\\F101"
        }
      },
      "operator-vscode": {
        "description": "VS Code session wrapper icon",
        "default": {
          "fontPath": "images/icons/dist/operator-icons.woff",
          "fontCharacter": "\\F104"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run generate:icons && npm run compile && npm run compile:webview",
    "copy-types": "node scripts/copy-types.js",
    "compile": "npm run copy-types && tsc -p ./",
    "compile:webview": "webpack --config webpack.webview.config.js --mode production",
    "watch": "npm run copy-types && tsc -watch -p ./",
    "watch:webview": "webpack --config webpack.webview.config.js --mode development --watch",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src webview-ui",
    "test": "vscode-test",
    "test:coverage": "node out/test/runTest.js",
    "package": "vsce package",
    "publish": "vsce publish",
    "publish:ovsx": "ovsx publish",
    "generate:icons": "fantasticon"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^5.18.0",
    "@mui/material": "^5.18.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "smol-toml": "^1.6.1"
  },
  "devDependencies": {
    "@istanbuljs/nyc-config-typescript": "^1.0.2",
    "@eslint/js": "^10.0.0",
    "@stylistic/eslint-plugin-ts": "^4.4.1",
    "@types/glob": "^9.0.0",
    "@types/mocha": "^10.0.6",
    "@types/node": "25.x",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/sinon": "^21.0.1",
    "@types/vscode": "^1.120.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.9.2",
    "c8": "^11.0.0",
    "css-loader": "^7.1.4",
    "eslint": "^10.4.1",
    "fantasticon": "^4.1.0",
    "glob": "^13.0.6",
    "mocha": "^11.7.5",
    "nyc": "^18.0.0",
    "ovsx": "^1.0.1",
    "sinon": "^22.0.0",
    "source-map-support": "^0.5.21",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.6.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.3"
  }
}
